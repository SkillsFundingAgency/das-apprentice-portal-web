@page
@using SFA.DAS.ApprenticePortal.SharedUi.Menu
@model SFA.DAS.ApprenticeCommitments.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Access Your Apprenticeship";
}
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-l">@ViewData["Title"]</h1>
        <p>
            If you're an apprentice, use this service to:
        </p>
        <ul class="govuk-list govuk-list--bullet">
            <li>check your apprenticeship details</li>
            <li>understand what's expected of you, your employer and your training provider during your apprenticeship</li>
            <li>get support for your apprenticeship</li>
            <li>join the apprenticeship ambassador network</li>
            <li>give feedback on your training provider</li>
        </ul>

        <p class="govuk-body">
            You can also do this on Your Apprenticeship app, which you can get from <a href="https://play.google.com/store/apps/details?id=uk.gov.education.myapprenticeship&hl=en-US" class="govuk-link" target="_blank" rel="noopener noreferrer">Google Play</a> or the <a href="https://apps.apple.com/gb/app/your-apprenticeship/id6738137983" class="govuk-link" target="_blank" rel="noopener noreferrer">App Store</a>.
        </p>

        <p class="govuk-body">
            You can only use this service if you're doing an apprenticeship, not if you're doing any other type of course.
        </p>

        <div class="govuk-inset-text">
            <p class="govuk-body">
                You need a GOV.UK One Login to sign in to this service. You can create one if you do not already have one.
            </p>
        </div>
       
        <a href="@Model.StartUrl" role="button" draggable="false" class="govuk-button govuk-button--start govuk-!-margin-top-2" data-module="govuk-button">
            Start now
            <svg class="govuk-button__start-icon" xmlns="http://www.w3.org/2000/svg"
                 width="17.5" height="19" viewBox="0 0 33 40" aria-hidden="true" focusable="false">
                <path fill="currentColor" d="M0 0h13l20 20-20 20H0l20-20z" />
            </svg>
        </a>

    </div>
</div>